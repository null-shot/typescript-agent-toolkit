{
	"name": "kv-mcp",
	"version": "0.2.0",
	"private": true,
	"main": "src/index.ts",
	"license": "MIT",
	"scripts": {
		"deploy": "wrangler deploy --env=\"\"",
		"deploy:dev": "wrangler deploy --env development",
		"deploy:staging": "wrangler deploy --env staging",
		"deploy:prod": "wrangler deploy --env production",
		"dev": "concurrently \"npx @modelcontextprotocol/inspector\" \"wrangler dev\" --kill-others",
		"dev:staging": "wrangler dev --env staging",
		"dev:prod": "wrangler dev --env production",
		"start": "wrangler dev",
		"build": "tsc --noEmit && wrangler deploy --dry-run",
		"test": "vitest run",
		"cf-typegen": "wrangler types",
		"kv:list": "wrangler kv:namespace list",
		"kv:create": "wrangler kv:namespace create kv_namespace_tet",
		"kv:create:preview": "wrangler kv:namespace create kv_namespace_tet --preview"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "catalog:",
		"@nullshot/test-utils": "workspace:*",
		"@types/node": "catalog:",
		"concurrently": "^9.2.1",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"wrangler": "catalog:"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "catalog:",
		"@nullshot/mcp": "workspace:*",
