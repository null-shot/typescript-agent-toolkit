/**
 * Single Worker — AI Agent + Playground UI + MCP Servers
 *
 * All components run in a single worker.
 * Zero subrequests between components — all internal Durable Object calls.
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "single-worker",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-11",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "development",
    "AI_PROVIDER": "workers-ai", // workers-ai (free), anthropic, openai, deepseek, google, grok
    "MODEL_ID": "", // Optional model override (e.g. "gpt-4o", "claude-3-haiku-20240307")
    "DEFAULT_NAME": "World", // Used by EnvVariableMcpServer
    "SECRET_NUMBER": "42", // Used by SecretMcpServer
  },
  // API keys: set via `wrangler secret put <KEY>` or .dev.vars for local dev
  // ANTHROPIC_API_KEY, OPEN_AI_API_KEY, DEEPSEEK_API_KEY,
  // GOOGLE_API_KEY, GROK_API_KEY, AI_PROVIDER_API_KEY
  // Durable Objects for Agents and MCP Servers
  "durable_objects": {
    "bindings": [
      // Agents
      {
        "name": "SIMPLE_PROMPT_AGENT",
        "class_name": "SimplePromptAgent",
      },
      {
        "name": "DEPENDENT_AGENT",
        "class_name": "DependentAgent",
      },
      // MCP Servers
      {
        "name": "TODO_MCP",
        "class_name": "TodoMcpServer",
      },
      {
        "name": "EXPENSE_MCP",
        "class_name": "ExpenseMcpServer",
      },
      {
        "name": "ENV_VARIABLE_MCP",
        "class_name": "EnvVariableMcpServer",
      },
      {
        "name": "SECRET_MCP",
        "class_name": "SecretMcpServer",
      },
      {
        "name": "IMAGE_MCP",
        "class_name": "ImageMcpServer",
      },
      {
        "name": "VOICE_MCP",
        "class_name": "VoiceMcpServer",
      },
      // New MCP Servers
      {
        "name": "KV_MCP",
        "class_name": "KvMcpServer",
      },
      {
        "name": "ANALYTICS_MCP",
        "class_name": "AnalyticsMcpServer",
      },
      {
        "name": "VECTORIZE_MCP",
        "class_name": "VectorizeMcpServer",
      },
      {
        "name": "BROWSER_MCP",
        "class_name": "BrowserMcpServer",
      },
      // EMAIL_MCP — inactive until custom domain + Cloudflare Email Routing is set up
      // Uncomment when iworker.online (or another domain) is verified and email routing enabled:
      // {
      //   "name": "EMAIL_MCP",
      //   "class_name": "EmailMcpServer",
      // },
    ],
  },
  // Migrations for Durable Objects
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "SimplePromptAgent",
        "DependentAgent",
        "TodoMcpServer",
        "ExpenseMcpServer",
        "EnvVariableMcpServer",
        "SecretMcpServer",
      ],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ImageMcpServer", "VoiceMcpServer"],
    },
    {
      "tag": "v3",
      "new_sqlite_classes": [
        "KvMcpServer",
        "AnalyticsMcpServer",
        "VectorizeMcpServer",
        "BrowserMcpServer",
      ],
    },
    // Uncomment when enabling EMAIL_MCP:
    // {
    //   "tag": "v4",
    //   "new_sqlite_classes": ["EmailMcpServer"],
    // },
  ],
  // Workers AI (for LLM inference, image gen, embeddings)
  "ai": {
    "binding": "AI",
  },
  // KV namespace (for KvMcpServer)
  "kv_namespaces": [
    {
      "binding": "EXAMPLE_KV",
      "id": "bbb6c2576b4b453e87fd29fa83682594",
    },
  ],
  // Analytics Engine (for AnalyticsMcpServer)
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "single_worker_analytics",
    },
  ],
  // Vectorize (for VectorizeMcpServer + optional chat memory)
  "vectorize": [
    {
      "binding": "VECTORIZE_INDEX",
      "index_name": "single-worker-semantic-search",
    },
    // Uncomment for RAG / long-term memory:
    // {
    //   "binding": "CHAT_MEMORY",
    //   "index_name": "single-worker-memory",
    // },
  ],
  // Browser Rendering (for BrowserMcpServer)
  "browser": {
    "binding": "MYBROWSER",
  },
  // R2 bucket (for BrowserMcpServer page cache) — optional
  // Enable R2 in CF Dashboard first, then uncomment:
  // "r2_buckets": [
  //   {
  //     "binding": "CACHE_BUCKET",
  //     "bucket_name": "single-worker-browser-cache",
  //   },
  // ],
  // Observability
  "observability": {
    "enabled": true,
  },
  // EMAIL_MCP — uncomment when domain is verified + email routing enabled:
  // "send_email": {
  //   "name": "SEND_EMAIL",
  //   "destination_address": "your-address@iworker.online",
  // },
  // Add to "vars" above when enabling:
  //   "MAIL_FROM": "noreply@iworker.online",
  //   "ALLOWED_RECIPIENTS": "@iworker.online",
}
