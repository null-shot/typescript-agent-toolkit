# ═══════════════════════════════════════════════════════════
# SECURITY — API keys, secrets, credentials
# ═══════════════════════════════════════════════════════════

# Cloudflare Workers local secrets
.dev.vars
.dev.varsy
**/.dev.vars
**/.dev.varsy

# Environment files (all variations)
.env
.env.*
!.env.example
!.env.*.example
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
*.der

# Credential files
*credentials*.json
*serviceAccountKey*.json
*service-account*.json
gcloud-credentials.json
firebase-adminsdk*.json

# Cloud provider config with potential secrets
.cloudflare/
.aws/
.gcp/

# Auth tokens / session files
*.token
.netrc
.npmrc
!.npmrc.example

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.*
.terraform/

# Docker env files
docker-compose.override.yml
.docker-env

# ═══════════════════════════════════════════════════════════
# Dependencies
# ═══════════════════════════════════════════════════════════
node_modules/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ═══════════════════════════════════════════════════════════
# TypeScript
# ═══════════════════════════════════════════════════════════
*.tsbuildinfo
dist/
build/
lib/
!/**/src/**/lib

# ═══════════════════════════════════════════════════════════
# Cloudflare Workers
# ═══════════════════════════════════════════════════════════
.wrangler/
**/.wrangler/

# ═══════════════════════════════════════════════════════════
