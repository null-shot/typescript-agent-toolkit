# ═══════════════════════════════════════════════════════════
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# ═══════════════════════════════════════════════════════════
# Testing
# ═══════════════════════════════════════════════════════════
coverage/
.nyc_output/

# ═══════════════════════════════════════════════════════════
# Debug logs
# ═══════════════════════════════════════════════════════════
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
debug.log
*.log

